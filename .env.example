# CDOM Pastoral Management System - Environment Variables
# Copy this file to .env and fill in your real values

# ==================== CORE ====================
PROJECT_NAME=CDOM Management System
VERSION=1.5.0

# ==================== DATABASE ====================
# PostgreSQL + asyncpg URL (required)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/cdom_db

# ==================== SECURITY ====================
# Generate a strong secret key (openssl rand -hex 32)
SECRET_KEY=change-this-to-a-very-long-random-string-at-least-32-characters

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==================== EXTERNAL SERVICES ====================
# Resend (email service) - get free key from https://resend.com
RESEND_API_KEY=your-resend-api-key-here

# ==================== OPTIONAL / PRODUCTION ====================
# Environment flag (development / staging / production)
ENVIRONMENT=development

# Rate limiting & CORS (used by middleware)
RATE_LIMIT_PER_MINUTE=100
CORS_ORIGINS=https://cdom-app.web.app,http://localhost:8080