### ============================================================================
### 1. REGISTER THE PARISH PRIEST ACCOUNT
### ============================================================================
POST http://192.168.18.9:8000/api/v1/auth/register
Content-Type: application/json

{
  "email": "ppstchristopher@domansa.org",
  "password": "SecurePassword123!",
  "role": "Parish Priest",
  "parish_id": 17,
  "deanery_id": 4
}

### ============================================================================
### 2. LOG IN THE PARISH PRIEST (CAPTURE TOKEN)
### ============================================================================
POST http://192.168.18.9:8000/api/v1/auth/login
Content-Type: application/x-www-form-urlencoded

username=ppstchristopher@domansa.org&password=SecurePassword123!

> {%
    client.global.set("pp_token", response.body.access_token);
%}


### ============================================================================
### 3. SECRETARY SUBMITS AN EDIT TO A BAPTISM RECORD
### ============================================================================
# Use your active Secretary token here!
@sec_token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJzZWNzdGNocmlzdG9waGVyQGRvbWFuc2Eub3JnIiwicm9sZSI6IlBhcmlzaCBTZWNyZXRhcnkiLCJwYXJpc2hfaWQiOjE3LCJkZWFuZXJ5X2lkIjo0LCJ0ZW5hbnRfc2NoZW1hIjoicGFyaXNoX3N0X2NocmlzdG9waGVyIiwic2Vzc2lvbl9pZCI6IjQ3NWM5NDYzLTg1MTEtNGIzMC04MmY1LWQ3MTc3MTJhYTQyMCIsImV4cCI6MTc3NDA3MDc5MX0.VS8uMFFIcCLS_WTnxxa8vgh7nUuJ-EQT-Pte0t0TW9g

POST http://192.168.18.9:8000/api/v1/approvals/submit
Content-Type: application/json
Authorization: Bearer {{sec_token}}

{
  "action_type": "UPDATE",
  "target_table": "baptisms",
  "target_record_id": "PASTE_THE_ELIAS_BAPTISM_UUID_HERE",
  "proposed_payload": {
    "first_name": "Elias (Corrected Spelling)",
    "village": "Mansa Central - Block B"
  }
}

> {%
    client.global.set("action_id", response.body.action_id);
%}


### ============================================================================
### 4. PRIEST CHECKS HIS INBOX
### ============================================================================
GET http://192.168.18.9:8000/api/v1/approvals/
Authorization: Bearer {{pp_token}}


### ============================================================================
### 5. PRIEST APPROVES THE EDIT
### ============================================================================
POST http://192.168.18.9:8000/api/v1/approvals/{{action_id}}/approve
Authorization: Bearer {{pp_token}}

### QUICK UTILITY: FIND ELIAS'S UUID
GET http://192.168.18.9:8000/api/v1/baptisms/search?q=Elias
Authorization: Bearer {{sec_token}}